  2529                           ;Config register CONFIG1 @ 0x2007
  2530                           ;	Oscillator Selection bits
  2531                           ;	FOSC = INTRC_NOCLKOUT, INTOSCIO oscillator: I/O function on RA6/OSC2/CLKOUT pin, I/O f
      +                          unction on RA7/OSC1/CLKIN
  2532                           ;	Watchdog Timer Enable bit
  2533                           ;	WDTE = OFF, WDT disabled and can be enabled by SWDTEN bit of the WDTCON register
  2534                           ;	Power-up Timer Enable bit
  2535                           ;	PWRTE = ON, PWRT enabled
  2536                           ;	RE3/MCLR pin function select bit
  2537                           ;	MCLRE = ON, RE3/MCLR pin function is MCLR
  2538                           ;	Code Protection bit
  2539                           ;	CP = OFF, Program memory code protection is disabled
  2540                           ;	Data Code Protection bit
  2541                           ;	CPD = 0x1, unprogrammed default
  2542                           ;	Brown Out Reset Selection bits
  2543                           ;	BOREN = ON, BOR enabled
  2544                           ;	Internal External Switchover bit
  2545                           ;	IESO = 0x1, unprogrammed default
  2546                           ;	Fail-Safe Clock Monitor Enabled bit
  2547                           ;	FCMEN = 0x1, unprogrammed default
  2548                           ;	Low Voltage Programming Enable bit
  2549                           ;	LVP = OFF, RB3 pin has digital I/O, HV on MCLR must be used for programming
  2550                           ;	In-Circuit Debugger Mode bit
  2551                           ;	DEBUG = 0x1, unprogrammed default
